<!DOCTYPE html>
<html lang="en">
<head>
    <script>
    (function() {
        const currentPath = window.location.pathname;
        const currentHost = window.location.host;
        
        // Specific detection for different deployments
        const isSTCDomain = currentHost === "students.iisertvm.ac.in" && currentPath.startsWith("/stc/");
        const isGitHubPages = currentHost.includes("github.io");
        const isSubdirectoryDeployment = currentPath.includes("/STC_IISERTVM/");
        
        // Determine the base path based on deployment
        let siteBasePath = "/";
        if (isSTCDomain) {
            siteBasePath = "/stc/";
        } else if (isSubdirectoryDeployment) {
            siteBasePath = "/STC_IISERTVM/";
        }
        
        function fixPath(originalPath) {
            if (!originalPath || originalPath.startsWith("http://") || originalPath.startsWith("https://") || originalPath.startsWith("//")) {
                return originalPath;
            }
            
            if (originalPath.startsWith("../")) {
                if (isSTCDomain || isSubdirectoryDeployment) {
                    const relativePath = originalPath.substring(3);
                    return siteBasePath + relativePath;
                } else {
                    return originalPath;
                }
            } else if (originalPath.startsWith("./") || (!originalPath.startsWith("/") && !originalPath.includes(":"))) {
                if (isSTCDomain || isSubdirectoryDeployment) {
                    const cleanPath = originalPath.replace("./", "");
                    return siteBasePath + "pages/" + cleanPath;
                } else {
                    return originalPath;
                }
            }
            
            return originalPath;
        }
        
        window.writeFixedCSS = function(originalPath) {
            const newPath = fixPath(originalPath);
            document.write('<link rel="stylesheet" href="' + newPath + '">');
        };
        
        window.writeFixedJS = function(originalPath) {
            const newPath = fixPath(originalPath);
            document.write('<script src="' + newPath + '"><\/script>');
        };
    })();
    </script>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQ - STC IISER TVM</title>
    <script>writeFixedCSS("../css/style.css");</script>
    <script>writeFixedCSS("navbar.css");</script>
</head>
<body>
    <!-- navbar-->
     <div id="navbar"> </div>

    <main>
        <section class="page-header">
            <div class="container">
                <h1>Frequently Asked Questions</h1>
                <p>Find answers to common questions about the STC, its clubs, and events.</p>
            </div>
        </section>

        <section id="faq-page" class="container">
            <div class="faq-accordion">
                <div class="faq-item">
                    <button class="faq-question">How can I join a club?</button>
                    <div class="faq-answer">
                        <p>Club registrations are typically opened at the beginning of each semester. An announcement will be made via email and on our social media channels. You can then register for the clubs of your choice through a form that will be circulated.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question">When is Anvesha held?</button>
                    <div class="faq-answer">
                        <p>Anvesha, our annual science fest, is usually held in the month of December. The exact dates are announced a few months in advance. Keep an eye on our Events page and social media for the announcement.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question">Can students from other colleges participate in Anvesha?</button>
                    <div class="faq-answer">
                        <p>Yes, absolutely! Anvesha is an intercollegiate fest, and we welcome students from all colleges and universities to participate in our events.</p>
                    </div>
                </div>
                <div class="faq-item">
                    <button class="faq-question">How is the STC council elected?</button>
                    <div class="faq-answer">
                        <p>The STC council is elected annually through a student body election. Any student who meets the eligibility criteria can nominate themselves for a position on the council. The elections are conducted in a fair and transparent manner.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer>
        <!-- Footer content is loaded dynamically by js/script.js -->
    </footer>

    <script>writeFixedJS("../js/data.js");</script>
    <script>writeFixedJS("../js/script.js");</script>
    <script>writeFixedJS("../js/faq.js");</script>
</body>
</html>
